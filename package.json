    "plugin",
    "calendar",
    "annual-planning"
  ],
  "author": "Codex",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.16.5",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.10",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2"
  }
}
