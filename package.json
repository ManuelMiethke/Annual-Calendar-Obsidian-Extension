{
  "name": "annual-calendar",
  "version": "0.2.0",
  "description": "A year-at-a-glance calendar plugin for Obsidian with date blocks, stamps, and two annual layouts.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "calendar",
    "annual-planning",
    "year-planning",
    "date-grid"
  ],
  "author": "Manuel Miethke",
  "license": "MIT",
  "homepage": "https://github.com/ManuelMiethke/Annual-Calendar-Obsidian-Extension",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ManuelMiethke/Annual-Calendar-Obsidian-Extension.git"
  },
  "bugs": {
    "url": "https://github.com/ManuelMiethke/Annual-Calendar-Obsidian-Extension/issues"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.10",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2"
  }
}
